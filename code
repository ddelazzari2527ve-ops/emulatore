#include <SPI.h>
#include <Arduino.h>

/* ==========================================================================
   CONFIGURAZIONE E CALIBRAZIONE
   ========================================================================== */

// --- PINOUT ESP32 (VSPI Standard) ---
const int PIN_CS = 5;    // Chip Select
const int PIN_SCK = 18;  // Clock
const int PIN_MOSI = 23; // Data In
const int PIN_MISO = 19; // Data Out (opzionale)

// --- PARAMETRI DI CALIBRAZIONE FISICA ---
// MISURA COL MULTIMETRO questi valori per eliminare l'errore di tolleranza!
const float CALIB_R_FIXED = 820.0;    // resistenza fissa misurata (Ohm)
const float CALIB_R_POT_AB = 5000.0;  // resistenza totale A-B potenziometro (Ohm)
const float CALIB_R_WIPER = 75.0;     // resistenza wiper a step 0 (Ohm)

// --- PARAMETRI PT1000 ---
const float R0 = 1000.0;
const float A_COEFF = 3.9083e-3;
const float B_COEFF = -5.775e-7;

/* ==========================================================================
   VARIABILI GLOBALI
   ========================================================================== */
float lastTemperature = -999.0;
uint16_t currentStepP1 = 0;
uint16_t currentStepP2 = 0;

/* ==========================================================================
   UTILITY
   ========================================================================== */
inline uint16_t clamp16(uint16_t v, uint16_t lo, uint16_t hi) {
  if (v < lo) return lo;
  if (v > hi) return hi;
  return v;
}
inline uint8_t toDeviceByte(uint16_t step) {
  // Mappa 0..256 (logica interna) su 0..255 per invio SPI
  if (step >= 256) return 255;
  return (uint8_t)step;
}

/* ==========================================================================
   FUNZIONI MATEMATICHE
   ========================================================================== */

// Converte Gradi Celsius in Ohm (Callendar-Van Dusen semplificata)
float getPt1000Ohms(float temp) {
  if (temp >= 0.0f) {
    return R0 * (1.0f + A_COEFF * temp + B_COEFF * temp * temp);
  } else {
    return R0 * (1.0f + A_COEFF * temp);
  }
}

// Calcola gli Ohm di un singolo potenziometro dato lo step (0-256 logico)
float getPotResistance(uint16_t step) {
  // Formula: R = R_wiper + R_AB * (step / 256)
  float s = (float)step / 256.0f;
  if (s > 1.0f) s = 1.0f;
  return CALIB_R_WIPER + (CALIB_R_POT_AB * s);
}

/* ==========================================================================
   SPI: invia i dati al chip via SPI
   Nota: verifica il formato comando sul datasheet del tuo potenziometro.
   Qui mantengo lo stesso schema di byte usato in origine ma mappando i
   valori su 0..255 per l'invio.
   ========================================================================== */
void writePotentiometers(uint16_t val1, uint16_t val2) {
  uint8_t b1 = toDeviceByte(val1);
  uint8_t b2 = toDeviceByte(val2);

  SPI.beginTransaction(SPISettings(10000000, MSBFIRST, SPI_MODE0));

  // Potenziometro 0 (Wiper 0) -> comando 0x00 (verificare datasheet)
  digitalWrite(PIN_CS, LOW);
  SPI.transfer(0x00);
  SPI.transfer(b1);
  digitalWrite(PIN_CS, HIGH);

  delayMicroseconds(5);

  // Potenziometro 1 (Wiper 1) -> comando 0x10 (verificare datasheet)
  digitalWrite(PIN_CS, LOW);
  SPI.transfer(0x10);
  SPI.transfer(b2);
  digitalWrite(PIN_CS, HIGH);

  SPI.endTransaction();
}

/* ==========================================================================
   ALGORITMO PRINCIPALE
   ========================================================================== */
void setSystemTemperature(float targetTemp) {
  // 1. Convertiamo gradi in Ohm Target (resistenza totale del PT1000)
  float targetOhmsTotal = getPt1000Ohms(targetTemp);

  // 2. Trend
  bool isRising = (targetTemp >= lastTemperature);

  // 3. Resistenza che devono fare i potenziometri (sottrai la resistenza fissa)
  float targetOhmsPotsOnly = targetOhmsTotal - CALIB_R_FIXED;

  // Saturazione: non scendere sotto il minimo fisico (metà wiper come safety)
  float minPossible = CALIB_R_WIPER; // valore realistico minimo
  if (targetOhmsPotsOnly < (minPossible * 0.5f)) targetOhmsPotsOnly = minPossible * 0.5f;

  // 4. Scansione della matrice virtuale
  uint16_t bestS1 = 0;
  uint16_t bestS2 = 0;
  float bestError = 1e9;
  bool found = false;

  // Loop ottimizzato: usiamo uint16_t per poter gestire 0..256 logico
  for (uint16_t s1 = 0; s1 <= 256; ++s1) {
    float r1 = getPotResistance(s1);

    // s2 parte da s1 per evitare duplicati (commutatività)
    for (uint16_t s2 = s1; s2 <= 256; ++s2) {
      float r2 = getPotResistance(s2);

      // Protezione divisione per zero
      float rParallel;
      float denom = r1 + r2;
      if (denom > 1e-6f) {
        rParallel = (r1 * r2) / denom;
      } else {
        rParallel = min(r1, r2);
      }

      float error = rParallel - targetOhmsPotsOnly;

      if (isRising) {
        // preferiamo approssimare per eccesso (errore >= 0)
        if (error >= 0.0f && error < bestError) {
          bestError = error;
          bestS1 = s1;
          bestS2 = s2;
          found = true;
          if (bestError <= 1e-6f) break; // trovato esatto
        }
      } else {
        // preferiamo approssimare per difetto (errore <= 0)
        if (error <= 0.0f && fabs(error) < bestError) {
          bestError = fabs(error);
          bestS1 = s1;
          bestS2 = s2;
          found = true;
          if (bestError <= 1e-6f) break; // trovato esatto
        }
      }
    }
    if (found && bestError <= 1e-6f) break;
  }

  // Fallback: se non trovato nulla con la logica trend, prendi il più vicino assoluto
  if (!found) {
    bestError = 1e9;
    for (uint16_t s1 = 0; s1 <= 256; ++s1) {
      float r1 = getPotResistance(s1);
      for (uint16_t s2 = s1; s2 <= 256; ++s2) {
        float r2 = getPotResistance(s2);
        float denom = r1 + r2;
        float rParallel = (denom > 1e-6f) ? (r1 * r2) / denom : min(r1, r2);
        float diff = fabs(rParallel - targetOhmsPotsOnly);
        if (diff < bestError) {
          bestError = diff;
          bestS1 = s1;
          bestS2 = s2;
        }
      }
    }
  }

  // 5. Applichiamo i valori hardware (mappando su 0..255 per il dispositivo)
  currentStepP1 = clamp16(bestS1, 0, 256);
  currentStepP2 = clamp16(bestS2, 0, 256);
  writePotentiometers(currentStepP1, currentStepP2);

  // 6. Output di Debug
  float r1_final = getPotResistance(bestS1);
  float r2_final = getPotResistance(bestS2);
  float r_final_par = (r1_final + r2_final > 1e-6f) ? (r1_final * r2_final) / (r1_final + r2_final) : min(r1_final, r2_final);
  float r_total_real = r_final_par + CALIB_R_FIXED;

  Serial.print("T: "); Serial.print(targetTemp, 2);
  Serial.print(" C -> Target PT1000: "); Serial.print(targetOhmsTotal, 3);
  Serial.print(" Ohm -> PotsOnly target: "); Serial.print(targetOhmsPotsOnly, 3);
  Serial.print(" Ohm -> Reale totale: "); Serial.print(r_total_real, 3);
  Serial.print(" Ohm [P1 step:"); Serial.print(bestS1);
  Serial.print(" P2 step:"); Serial.print(bestS2);
  Serial.print(" | R1:"); Serial.print(r1_final, 3);
  Serial.print(" R2:"); Serial.print(r2_final, 3);
  Serial.print(" Rpar:"); Serial.print(r_final_par, 3);
  Serial.print(" err:"); Serial.print(bestError, 6);
  Serial.println("]");
  
  lastTemperature = targetTemp;
}

/* ==========================================================================
   SETUP E LOOP
   ========================================================================== */
void setup() {
  Serial.begin(115200);
  pinMode(PIN_CS, OUTPUT);
  digitalWrite(PIN_CS, HIGH);
  SPI.begin(PIN_SCK, PIN_MISO, PIN_MOSI, PIN_CS);

  Serial.println("--- SIMULATORE PT1000 AVVIATO ---");
  Serial.println("Inserisci una temperatura nel monitor seriale (es. 24.3)");
  Serial.print("Resistenza Fissa Calibrata: "); Serial.println(CALIB_R_FIXED);
}

void loop() {
  if (Serial.available() > 0) {
    String line = Serial.readStringUntil('\n');
    line.trim();
    if (line.length() == 0) return;
    float tempReq = line.toFloat();
    setSystemTemperature(tempReq);
  }
}
